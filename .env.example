BOT_TOKEN=your_telegram_bot_token

# RapidAPI — Numerology API4 (javathinked)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=numerology-api4.p.rapidapi.com

# Сервис расчёта на VPS (Docker Compose задаёт автоматически в docker-compose.yml).
# Для локальной разработки без Docker, если calc запущен вручную:
# CALC_SERVICE_URL=http://127.0.0.1:8791

# ИИ-расшифровка (DeepSeek)
OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
AI_MAX_TOKENS=20000
